# Local dev infrastructure config.
# Copy thành .env nếu muốn override; mặc định compose dùng các giá trị này.
# QUAN TRỌNG: Credentials default ở đây KHỚP với default của backend
# (gateway/backend/.../application.yml). Đổi thì phải đổi cả 2.

# PostgreSQL
POSTGRES_DB=smpp_db
POSTGRES_USER=smpp_user
POSTGRES_PASSWORD=smpp_pass

# Redis (để trống = không bật password — khớp default backend)
# REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_USER=smpp_admin
RABBITMQ_PASSWORD=smpp_pass
RABBITMQ_ERLANG_COOKIE=vosb_local_cookie
