# Copy thành `.env` trước khi `docker compose up`. KHÔNG commit `.env` (đã trong .gitignore).

# Spring profile
SPRING_PROFILES_ACTIVE=prod

# Image tag (override khi tag release: smpp-server:0.1.0).
IMAGE_TAG=dev

# --- Postgres ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=smpp_db
DB_USER=smpp_user
DB_PASSWORD=change-me-strong-password

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- RabbitMQ ---
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=smpp_admin
RABBITMQ_PASSWORD=change-me-strong-password

# --- App secrets (≥32 bytes) ---
APP_JWT_SECRET=change-me-jwt-secret-min-32-bytes-aaaaaaaa
APP_SECRET_KEY=change-me-aes-256-key-32-bytes-XXXXXXX!

# --- Port bindings ---
# HTTP qua loopback (Nginx forward). Prod giữ 127.0.0.1.
HTTP_BIND=127.0.0.1:8080
# SMPP cần expose ra public cho partner bind. Prod set 0.0.0.0:2775.
SMPP_BIND=127.0.0.1:2775
